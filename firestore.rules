rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function requesterExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function requesterData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function requesterIsProfessional() {
      return requesterExists()
        && requesterData().tipo == 'profissional';
    }

    function requesterIsPatient() {
      return requesterExists()
        && requesterData().tipo == 'paciente';
    }

    function patientCanReadLinkedProfessional() {
      return requesterIsPatient()
        && resource.data.tipo == 'profissional'
        && request.auth.uid in resource.data.pacientesVinculados;
    }

    function professionalCanUpdatePatientLinks() {
      return requesterIsProfessional()
        && resource.data.tipo == 'paciente'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'profissionaisVinculados'
        ]);
    }

    function patientCanRemoveSelfFromProfessional() {
      return requesterIsPatient()
        && resource.data.tipo == 'profissional'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'pacientesVinculados'
        ])
        && !(request.auth.uid in request.resource.data.pacientesVinculados);
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;

      allow read: if isOwner(userId)
        || (requesterIsProfessional() && resource.data.tipo == 'paciente')
        || patientCanReadLinkedProfessional();

      allow update: if isOwner(userId)
        || professionalCanUpdatePatientLinks()
        || patientCanRemoveSelfFromProfessional();

      allow delete: if isOwner(userId);

      match /registros/{registroId} {
        allow read: if isOwner(userId)
          || (
            requesterIsProfessional()
            && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.profissionaisVinculados
          );

        allow create, update, delete: if isOwner(userId);
      }

      match /medicacoes/{medicacaoId} {
        allow read: if isOwner(userId)
          || (
            requesterIsProfessional()
            && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.profissionaisVinculados
          );

        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}
